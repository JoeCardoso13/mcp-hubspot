{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.joecardoso13/hubspot",
  "title": "HubSpot",
  "description": "MCP server for the HubSpot CRM API — manage contacts, companies, and deals",
  "version": "0.3.0",
  "websiteUrl": "https://github.com/JoeCardoso13",
  "repository": {
    "url": "https://github.com/JoeCardoso13/mcp-hubspot",
    "source": "github"
  },
  "packages": [
    {
      "registryType": [
        "mcpb",
        "pypi"
      ],
      "registryBaseUrl": "https://pypi.org",
      "identifier": "mcp-hubspot",
      "version": "0.1.0",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "HUBSPOT_ACCESS_TOKEN",
          "description": "HubSpot private app access token",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ],
  "_meta": {
    "io.modelcontextprotocol.registry/publisher-provided": {
      "tool": "mcpb",
      "version": "0.4"
    },
    "org.mpaktrust": {
      "mtf_version": "0.1",
      "permissions": {
        "network": [
          "api.hubapi.com"
        ],
        "filesystem": "none",
        "subprocess": "none"
      }
    }
  }
}
